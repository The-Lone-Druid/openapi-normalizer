{
  "name": "openapi-normalizer",
  "version": "1.0.0",
  "description": "Convert Postman Collections to OpenAPI 3.x and normalize bloated Postman-exported specs — correlated examples, inferred schemas, zero dependencies.",
  "author": "Zahid Shaikh <reachtozahid@gmail.com> (https://github.com/The-Lone-Druid)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "openapi-normalizer": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "pnpm lint && pnpm test"
  },
  "keywords": [
    "openapi",
    "openapi3",
    "openapi-3",
    "postman",
    "postman-collection",
    "postman-to-openapi",
    "postman-collection-v2",
    "normalizer",
    "converter",
    "swagger",
    "api",
    "api-spec",
    "api-documentation",
    "api-client",
    "openapi-generator",
    "code-generation",
    "schema-inference",
    "swagger-ui",
    "redocly",
    "stoplight",
    "typescript",
    "zero-dependency",
    "cli"
  ],
  "author": "The-Lone-Druid (https://github.com/The-Lone-Druid)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Lone-Druid/openapi-normalizer.git"
  },
  "homepage": "https://the-lone-druid.github.io/openapi-normalizer/",
  "bugs": {
    "url": "https://github.com/The-Lone-Druid/openapi-normalizer/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.3.0",
      "esbuild": "~0.25.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
